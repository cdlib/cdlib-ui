{{#extend "tool"}}{{#content "body"}}

<div class="tool-index">
  <header>
    <h1>CDLIB UI Toolkit</h1>
    <a href="https://github.com/cdlib/cdlib-ui" target="_blank">GitHub Repository</a>
  </header>
  <aside>
    <fieldset>
      <legend>View Mode</legend>
      <input id="view-preview" type="radio" name="view" value="preview">
      <label for="view-preview">Preview</label>
      <input id="view-fullpage" type="radio" name="view" value="fullpage">
      <label for="view-fullpage">Full Page</label>
    </fieldset>
    <nav>
      <h2>Templates</h2>
      <ul>
        <li>Template</li>
      </ul>
      <h2>Pages</h2>
      <ul>
        <li>Page</li>
      </ul>
      <h2>Components</h2>
      <ul>
        <li><a href="src/components/avatar-view.hbs">Avatar</a></li>
        <li><a href="src/components/blogmetadata-view.hbs">Blog Metadata</a></li>
        <li><a href="src/components/blogresult-view.hbs">Blog Result</a></li>
        <li><a href="src/components/breadcrumb-view.hbs">Breadcrumb</a></li>
        <li><a href="src/components/categories-view.hbs">Categories</a></li>
      </ul>
      <h2>Objects</h2>
      <ul>
        <li><a href="src/objects/blockquote-view.hbs">Blockquotes</a></li>
        <li><a href="src/objects/button-view.hbs">Buttons</a></li>
        <li><a href="src/objects/details-view.hbs">Details</a></li>
        <li><a href="src/objects/figure-view.hbs">Figures &amp; Captions</a></li>
        <li><a href="src/objects/heading-view.hbs">Headings</a></li>
        <li><a href="src/objects/input-view.hbs">Inputs</a></li>
        <li><a href="src/objects/label-view.hbs">Labels</a></li>
        <li><a href="src/objects/link-view.hbs">Links</a></li>
        <li><a href="src/objects/list-view.hbs">Lists</a></li>
        <li><a href="src/objects/paragraph-view.hbs">Paragraphs</a></li>
        <li><a href="src/objects/rule-view.hbs">Rules</a></li>
        <li><a href="src/objects/select-view.hbs">Selects</a></li>
        <li><a href="src/objects/table-view.hbs">Tables</a></li>
      </ul>
    </nav>
  </aside>
  <main>
    <iframe class="tool-preview" src="tool/preview.hbs" name="preview" frameborder="0"></iframe>
  </main>
</div>

{{/content}}{{/extend}}
