{{#extend "tool"}}{{#content "body"}}

<div class="tool-index">
  <header>
    <h1>CDLIB UI Toolkit</h1>
    <a href="https://github.com/cdlib/cdlib-ui" target="_blank">GitHub Repository</a>
  </header>
  <aside>
    <fieldset>
      <legend>View Mode</legend>
      <input id="view-preview" type="radio" name="view" value="preview">
      <label for="view-preview">Preview</label>
      <input id="view-fullpage" type="radio" name="view" value="fullpage">
      <label for="view-fullpage">Full Page</label>
    </fieldset>
    <nav>
      <h2>Templates</h2>
      <ul>
        <li>Template</li>
      </ul>
      <h2>Pages</h2>
      <ul>
        <li>Page</li>
      </ul>
      <h2>Components</h2>
      <ul>
        <li>Component</li>
      </ul>
      <h2>Objects</h2>
      <ul>
        <li><a href="src/objects/blockquote-view.hbs">Blockquotes</a></li>
      </ul>
    </nav>
  </aside>
  <main>
    <iframe class="tool-preview" src="tool/preview.hbs" name="preview" frameborder="0"></iframe>
  </main>
</div>

{{/content}}{{/extend}}
